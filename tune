app = typer.Typer(no_args_is_help=False, add_completion=False, rich_markup_mode="rich")
console = Console()
err_console = Console(stderr=True)

PROJECT_ROOT = Path(__file__).resolve().parent
PLAYBOOK_PATH = PROJECT_ROOT / "d1-retention-analysis.md"
SHEET_PATH = PROJECT_ROOT / "data" / "sheets" / "d1_retention.csv"
CONFIG_PATH = PROJECT_ROOT / "config.yaml"
OUTPUTS_DIR = PROJECT_ROOT / "outputs"
MCP_SERVER_PATH = PROJECT_ROOT / "tune_mcp.py"

ALLOWED_MCP_TOOLS = " ".join(
    f"mcp__sandbox__{name}" for name in ("list_files", "load_file")
)


