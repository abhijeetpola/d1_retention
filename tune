def _load_config() -> dict[str, Any]:
    if not CONFIG_PATH.exists():
        _die(f"config not found: {CONFIG_PATH}")
    return yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8"))


def _ensure_environment(
    *, cli_required: str | None, verbose: bool = False
) -> None:
    """Light pre-flight for every ./tune call.

    `cli_required` is the provider name whose CLI must be present ('claude' or
    'codex'), or None for dry-run / doctor (which run their own checks).
    """
    if not PLAYBOOK_PATH.exists():
        _die(f"playbook not found: {PLAYBOOK_PATH}")
    if verbose:
        console.print(f"[green]✓[/green] playbook present: {PLAYBOOK_PATH.name}")

    if not SHEET_PATH.exists():
        _die(
            f"sheet not found: {SHEET_PATH}\n"
            "  An engineer drops the source CSV into data/sheets/ once."
        )
    if verbose:
        rows = sum(1 for _ in SHEET_PATH.open()) - 1
        console.print(f"[green]✓[/green] sheet present: {SHEET_PATH.name} ({rows:,} rows)")

    if not MCP_SERVER_PATH.exists():
        _die(f"MCP server missing: {MCP_SERVER_PATH}")
    if verbose:
        console.print(f"[green]✓[/green] MCP server present: {MCP_SERVER_PATH.name}")

    cli_required_to_binary = {"claude": "claude", "codex": "codex"}
    if cli_required:
        binary = cli_required_to_binary.get(cli_required)
        if not binary:
            _die(f"unknown cli requirement: {cli_required!r}")
        if shutil.which(binary) is None:
            install_hint = (
                "Install Claude Code (https://claude.com/code) and run `claude` once to log in."
                if binary == "claude"
                else "Install OpenAI Codex CLI and run `codex login` once."
            )
            _die(f"`{binary}` CLI not found on PATH.\n  {install_hint}")
        if verbose:
            console.print(f"[green]✓[/green] {binary} CLI present on PATH")


def _compute_sheet_stats() -> dict[str, Any]:
    """Read the retention sheet and return shape + date-range stats for the banner.

    The banner shows full-sheet rows × cols and the date range covered. The LLM
    fetches every retention number through MCP tools at run time; nothing from
    the sheet is inlined into the prompt.
    """
    df = pd.read_csv(SHEET_PATH, thousands=",", low_memory=False)
    df["date"] = pd.to_datetime(df["date"], errors="coerce")
    df = df.dropna(subset=["date"])
    return {
        "full_total_rows": len(df),
        "full_total_cols": len(df.columns),
        "full_min_date": df["date"].min().strftime("%Y-%m-%d") if len(df) else "?",
        "full_max_date": df["date"].max().strftime("%Y-%m-%d") if len(df) else "?",
    }


def _list_docs() -> list[str]:
    """Filenames of any docs the PM has dropped into data/docs/."""
    docs_dir = PROJECT_ROOT / "data" / "docs"
    if not docs_dir.exists():
        return []
    return sorted(
        p.name
        for p in docs_dir.iterdir()
        if p.is_file() and not p.name.startswith(".")
    )


def _print_preflight(
    *,
    prose: str,
    sheet_stats: dict[str, Any],
    docs: list[str],
    model_display: str,
    pm_query: str,
) -> None:
    """Layer 1 — static info shown before Claude is invoked."""
    word_count = len(prose.split())
    docs_line = ", ".join(docs) if docs else "none yet"

    console.print()
    console.print(
        f"[bold]Playbook:[/bold]   [cyan]{PLAYBOOK_PATH.name}[/cyan] "
        f"[dim]({word_count:,} words)[/dim]"
    )
    console.print(
        f"[bold]Data:[/bold]       full sheet via MCP tools "
        f"[dim]({sheet_stats['full_total_rows']:,} rows × "
        f"{sheet_stats['full_total_cols']} cols, "
        f"{sheet_stats['full_min_date']} → {sheet_stats['full_max_date']})[/dim]"
    )
    console.print(f"[bold]Extra docs:[/bold] [dim]{docs_line}[/dim]")
    console.print(f"[bold]Model:[/bold]      [dim]{model_display}[/dim]")
    if pm_query:
        console.print()
        console.print(
            Panel(pm_query, title="PM query for this run", border_style="dim")
        )
    console.print()


def _build_user_message(*, prose: str, pm_query: str = "") -> str:
    parts = [
        "# PM playbook (the prose to follow)",
        "",
        prose.strip(),
        "",
        "---",
        "",
        "# Tools you have available",
        "",
        "All retention data is reached through MCP tools — there is no inlined "
        "data table in this prompt. The deterministic-math tools "
        "(`compute_rolling_average`, `compute_stable_baseline`, "
        "`compare_to_baseline`, `flag_dip_days`, `compute_signals_for_day`, "
        "`compute_acquisition_mix_shift`) cover every threshold and baseline "
        "calculation. Use `get_rows(platform, acquisition_source, date_from, "
        "date_to, days, columns)` when the question is \"show me the data\" "
        "rather than \"compute one number.\"",
        "",
        "- `list_files()` — see all files under data/",
        "- `load_file('docs/<file.md>')` — load a context document",
        "- `load_file('sheets/d1_retention.csv')` — load the FULL sheet "
        "(last resort; prefer `get_rows` for targeted slices)",
    ]
    if pm_query:
        parts.extend(
            [
                "",
                "---",
                "",
                "# PM's specific question for THIS run",
                "",
                "The playbook above sets the framing. For this particular run, the PM has "
                "added an extra question they want you to focus on. Treat it as the "
                "primary lens for your report — answer it directly in the TL;DR and "
                "refer back to it explicitly in your verdicts and findings.",
                "",
                f"> {pm_query}",
            ]
        )
    parts.extend(["", "Begin your investigation."])
    return "\n".join(parts)


def _invoke_claude(
    *,
    system_prompt: str,
    user_message: str,
    model: str,
    progress: Progress | None = None,
) -> dict[str, Any]:
    """Launch claude -p in stream-json mode and translate live events into status lines."""
    mcp_config = {
        "mcpServers": {
            "sandbox": {
                "command": sys.executable,
                "args": [str(MCP_SERVER_PATH)],
            }
        }
    }
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".json", delete=False, dir=str(PROJECT_ROOT)
    ) as f:
        mcp_config_path = Path(f.name)
        json.dump(mcp_config, f)

    state: dict[str, Any] = {
        "result": None,
        # Dedupe: stream-json may emit the same tool_use both as a top-level
        # `assistant` event and inside `stream_event` envelopes. Use the tool_use
        # id (when present) to print each call exactly once.
        "seen_tool_use_ids": set(),
    }
    stderr_text = ""

    try:
        cmd = [
            "claude",
            "-p",
            "--output-format", "stream-json",
            "--verbose",
            "--model", model,
            "--mcp-config", str(mcp_config_path),
            "--allowed-tools", ALLOWED_MCP_TOOLS,
            "--system-prompt", system_prompt,
        ]
        proc = subprocess.Popen(
            cmd,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,  # line-buffered
        )
        assert proc.stdin is not None and proc.stdout is not None and proc.stderr is not None

        # Send the prompt and close stdin so claude knows we're done.
        proc.stdin.write(user_message)
        proc.stdin.close()

        for raw_line in proc.stdout:
            line = raw_line.strip()
            if not line:
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            try:
                _handle_stream_event(event, progress, state)
            except Exception:
                # Never let a parsing quirk kill the whole run.
                continue

        proc.wait()
        stderr_text = proc.stderr.read() or ""

        if proc.returncode != 0:
            _die(
                f"claude exited {proc.returncode}\n  "
                f"stderr (last 800 chars): {stderr_text[-800:]}"
            )
    finally:
        mcp_config_path.unlink(missing_ok=True)

    payload = state["result"]
    if payload is None:
        _die(
            "claude finished without emitting a final result event.\n  "
            f"stderr (last 800 chars): {stderr_text[-800:]}"
        )

    if payload.get("is_error"):
        _die(f"claude reported error: {payload.get('result', '<no detail>')}")

    usage = payload.get("usage", {}) or {}
    return {
        "text": payload.get("result", "") or "",
        "duration_ms": int(payload.get("duration_ms", 0)),
        "cost_usd": float(payload.get("total_cost_usd", 0.0) or 0.0),
        "input_tokens": int(usage.get("input_tokens", 0) or 0),
        "output_tokens": int(usage.get("output_tokens", 0) or 0),
    }


# ---------------------------------------------------------------------------
# Codex CLI invocation — parallel path for OpenAI / GPT models.
#
# Codex `exec` does not have a separate --system-prompt flag; the system
# preamble is prepended to the user message instead. MCP servers are wired in
# via TOML config overrides on -c.
# ---------------------------------------------------------------------------


def _invoke_codex(
    *,
    system_prompt: str,
    user_message: str,
    model: str,
    progress: Progress | None = None,
) -> dict[str, Any]:
    """Launch codex exec in JSONL mode, stream events, capture the final message."""
    # Codex has no --system-prompt; prepend the preamble into the prompt.
    full_message = (
        f"# System instructions (read first; non-negotiable)\n\n"
        f"{system_prompt}\n\n"
        f"---\n\n"
        f"{user_message}"
    )

    # Final assistant message lands in this file via --output-last-message.
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".txt", delete=False, dir=str(PROJECT_ROOT)
    ) as f:
        last_msg_path = Path(f.name)

    state: dict[str, Any] = {"events": 0}
    stderr_text = ""
    start_ts = datetime.now()

    try:
        # MCP server wiring as TOML overrides. The args list uses TOML array syntax.
        mcp_args_toml = f'["{MCP_SERVER_PATH}"]'
        cmd = [
            "codex", "exec",
            "--json",
            "--full-auto",
            "--skip-git-repo-check",
            "--model", model,
            "--output-last-message", str(last_msg_path),
            "-c", f'mcp_servers.sandbox.command="{sys.executable}"',
            "-c", f'mcp_servers.sandbox.args={mcp_args_toml}',
        ]
        proc = subprocess.Popen(
            cmd,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        assert proc.stdin is not None and proc.stdout is not None and proc.stderr is not None

        proc.stdin.write(full_message)
        proc.stdin.close()

        for raw_line in proc.stdout:
            line = raw_line.strip()
            if not line:
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            try:
                _handle_codex_event(event, progress, state)
            except Exception:
                continue

        proc.wait()
        stderr_text = proc.stderr.read() or ""

        if proc.returncode != 0:
            _die(
                f"codex exited {proc.returncode}\n  "
                f"stderr (last 800 chars): {stderr_text[-800:]}"
            )
    finally:
        text = last_msg_path.read_text(encoding="utf-8") if last_msg_path.exists() else ""
        last_msg_path.unlink(missing_ok=True)

    if not text:
        _die(
            "codex finished but produced no final message.\n  "
            f"stderr (last 800 chars): {stderr_text[-800:]}"
        )

    duration_ms = int((datetime.now() - start_ts).total_seconds() * 1000)
    return {
        "text": text,
        "duration_ms": duration_ms,
        # Codex doesn't expose cost/tokens in the JSONL stream the same way
        # Claude does; leave as zeros so the caller's summary line still works.
        "cost_usd": 0.0,
        "input_tokens": 0,
        "output_tokens": 0,
    }


def _handle_codex_event(
    event: dict[str, Any], progress: Progress | None, state: dict[str, Any]
) -> None:
    """Translate one codex JSONL event into an activity-feed line.

    Codex's JSONL schema is different from Claude's stream-json. We try to
    surface tool calls and tool results without claiming to know every event
    type. Anything we don't recognise is skipped silently.
    """
    state["events"] = state.get("events", 0) + 1
    etype = event.get("type") or event.get("msg", {}).get("type") or ""
    msg = event.get("msg") or event

    # MCP tool call (codex emits a few different shapes depending on version).
    if etype in ("mcp_tool_call_begin", "tool_call_begin", "function_call"):
        invocation = msg.get("invocation") or msg.get("call") or {}
        tool_name = (
            invocation.get("tool")
            or msg.get("tool_name")
            or msg.get("name")
            or ""
        )
        tool_input = invocation.get("arguments") or msg.get("arguments") or {}
        if isinstance(tool_input, str):
            try:
                tool_input = json.loads(tool_input)
            except json.JSONDecodeError:
                tool_input = {"raw": tool_input}
        # Codex prefixes MCP tool names with the server name (e.g. "sandbox").
        normalised_name = tool_name.replace("sandbox.", "mcp__sandbox__").replace(
            ".", "__"
        )
        if not normalised_name.startswith("mcp__"):
            normalised_name = f"mcp__sandbox__{tool_name}"
        _print_tool_call(progress, normalised_name, tool_input)
        return

    if etype in ("mcp_tool_call_end", "tool_call_end", "function_call_output"):
        result = msg.get("result") or msg.get("output") or msg.get("content") or ""
        if isinstance(result, dict):
            result_text = json.dumps(result)
        elif isinstance(result, list):
            parts = []
            for item in result:
                if isinstance(item, dict) and item.get("type") == "text":
                    parts.append(item.get("text", ""))
                elif isinstance(item, str):
                    parts.append(item)
            result_text = "".join(parts)
        else:
            result_text = str(result or "")
        summary = _summarize_tool_result(result_text)
        if summary.startswith("(failed"):
            _activity_print(progress, f"[red]← {summary}[/red]")
        else:
            _activity_print(progress, f"[dim]← {summary}[/dim]")
        return

    # Codex agent reasoning / message events; ignore in the activity feed.
    # The final message is captured via --output-last-message instead.
    return


# ---------------------------------------------------------------------------
# stream-json event handling — Layer 2 (live activity feed)
# ---------------------------------------------------------------------------


def _handle_stream_event(
    event: dict[str, Any], progress: Progress | None, state: dict[str, Any]
) -> None:
    """Translate one stream-json line into a status update (and capture the result)."""
    etype = event.get("type")

    if etype == "result":
        state["result"] = event
        return

    if etype == "assistant":
        # Top-level assistant message with finalized content blocks.
        message = event.get("message") or {}
        for block in message.get("content") or []:
            if block.get("type") == "tool_use":
                tu_id = block.get("id") or ""
                if tu_id and tu_id in state["seen_tool_use_ids"]:
                    continue
                if tu_id:
                    state["seen_tool_use_ids"].add(tu_id)
                _print_tool_call(
                    progress,
                    block.get("name", ""),
                    block.get("input") or {},
                )
        return

    if etype == "user":
        # Tool result emitted as a "user" turn.
        message = event.get("message") or {}
        for block in message.get("content") or []:
            if block.get("type") == "tool_result":
                _print_tool_result(progress, block)
        return

    if etype == "stream_event":
        # Raw API streaming events. Only act on content_block_start with a
        # complete tool_use payload — partial input deltas are too noisy to surface.
        inner = event.get("event") or {}
        if inner.get("type") == "content_block_start":
            cb = inner.get("content_block") or {}
            if cb.get("type") == "tool_use":
                tu_id = cb.get("id") or ""
                if tu_id and tu_id in state["seen_tool_use_ids"]:
                    return
                if tu_id:
                    state["seen_tool_use_ids"].add(tu_id)
                _print_tool_call(progress, cb.get("name", ""), cb.get("input") or {})
        return

    # `system` (init) and any unknown types: ignore silently.


def _print_tool_call(
    progress: Progress | None, tool_name: str, tool_input: dict[str, Any]
) -> None:
    if tool_name.endswith("__list_files"):
        line = "→ Listing files available in data/..."
    elif tool_name.endswith("__load_file"):
        filename = (tool_input or {}).get("filename") or "<unknown>"
        if filename.startswith("sheets/"):
            line = f"→ Loading the FULL sheet ({filename}) for per-source detail..."
        elif filename.startswith("docs/"):
            line = f"→ Loading {filename} for further analysis..."
        else:
            line = f"→ Loading {filename}..."
    else:
        line = f"→ {tool_name}({tool_input})"
    _activity_print(progress, f"[dim]{line}[/dim]")


def _print_tool_result(progress: Progress | None, block: dict[str, Any]) -> None:
    raw = block.get("content")
    text = ""
    if isinstance(raw, str):
        text = raw
    elif isinstance(raw, list):
        for item in raw:
            if isinstance(item, dict) and item.get("type") == "text":
                text += item.get("text", "")
            elif isinstance(item, str):
                text += item

    summary = _summarize_tool_result(text)
    if summary.startswith("(failed"):
        _activity_print(progress, f"[red]← {summary}[/red]")
    else:
        _activity_print(progress, f"[dim]← {summary}[/dim]")


_ROWS_COLS_RE = re.compile(r"(\d{1,3}(?:,\d{3})*|\d+)\s*rows\s*×\s*(\d+)\s*columns?")
_ERROR_RE = re.compile(r'"error"\s*:\s*"([^"]+)"')
_FILES_RE = re.compile(r'"files"\s*:\s*\[([^\]]*)\]', re.DOTALL)
_QUOTED_STR_RE = re.compile(r'"[^"]*"')


def _summarize_tool_result(text: str) -> str:
    """Best-effort one-line summary of an MCP tool response."""
    if not text:
        return "Loaded"

    # Try a clean JSON parse first — our tools return well-formed JSON dicts.
    parsed: Any = None
    try:
        parsed = json.loads(text)
    except (json.JSONDecodeError, TypeError):
        parsed = None

    if isinstance(parsed, dict):
        if parsed.get("ok") is False:
            err = str(parsed.get("error") or "unknown error")
            return f"(failed: {err[:80]})"
        if "files" in parsed and isinstance(parsed["files"], list):
            n = len(parsed["files"])
            return f"Found {n} file{'' if n == 1 else 's'}"
        content = parsed.get("content")
        if isinstance(content, str):
            m = _ROWS_COLS_RE.search(content)
            if m:
                return f"Loaded ({m.group(1)} rows × {m.group(2)} cols)"
            return f"Loaded ({len(content):,} chars)"

    # Fallback regex path for non-JSON or wrapped payloads.
    if '"ok": false' in text or '"ok":false' in text:
        m = _ERROR_RE.search(text)
        err = m.group(1) if m else "unknown error"
        return f"(failed: {err[:80]})"

    m = _FILES_RE.search(text)
    if m:
        body = m.group(1).strip()
        count = 0 if not body else len(_QUOTED_STR_RE.findall(body))
        return f"Found {count} file{'' if count == 1 else 's'}"

    m = _ROWS_COLS_RE.search(text)
    if m:
        return f"Loaded ({m.group(1)} rows × {m.group(2)} cols)"

    return "Loaded"


def _activity_print(progress: Progress | None, message: str) -> None:
    """Print a live status line without disturbing the spinner."""
    target = progress.console if progress is not None else console
    target.print(message)


def _resolve_output_path(template: str) -> Path:
    now = datetime.now()
    rendered = (
        template.replace("{date}", now.strftime("%Y-%m-%d"))
        .replace("{time}", now.strftime("%H%M%S"))
        .replace("{basename}", PLAYBOOK_PATH.stem)
    )
    return PROJECT_ROOT / rendered


def _update_latest_symlink(target: Path) -> None:
    latest = OUTPUTS_DIR / "latest.md"
    if latest.exists() or latest.is_symlink():
        latest.unlink()
    latest.symlink_to(target.name)  # relative link inside outputs/


def _die(message: str, extra: str = "") -> None:
    err_console.print(f"[bold red]✗[/bold red] {message}")
    if extra:
        err_console.print(extra)
    raise typer.Exit(code=1)


_KNOWN_COMMANDS = {"run", "doctor"}


def main() -> None:
    # If invoked with no command, or with a flag, or with a positional arg that
    # is NOT a known subcommand, default to `run`. This lets PMs type either:
    #   ./tune
    #   ./tune --dry-run
    #   ./tune doctor
    #   ./tune "Why did D1 dip on March 8?"
    #   ./tune why did D1 dip on March 8
    if len(sys.argv) == 1:
        sys.argv.insert(1, "run")
    elif sys.argv[1].startswith("-") or sys.argv[1] not in _KNOWN_COMMANDS:
        sys.argv.insert(1, "run")
    app()


if __name__ == "__main__":
    main()
