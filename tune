@app.command()
def run(
    query: list[str] = typer.Argument(
        None,
        help=(
            "Optional ad-hoc question to send alongside the playbook prose. "
            "Append it as words after ./tune (quote it for safety)."
        ),
    ),
    dry_run: bool = typer.Option(
        False, "--dry-run", help="Build the prompt and print it; do NOT call claude."
    ),
    verify: bool = typer.Option(
        False,
        "--verify",
        help=(
            "Validate the playbook's tool calls against the live MCP registry. "
            "Imports every tool file (catches Python errors) and checks each "
            "tool reference in the playbook for unknown names or invalid "
            "parameters. No LLM call. Returns 0 if clean, non-zero on errors."
        ),
    ),
    no_open: bool = typer.Option(
        False,
        "--no-open",
        help="Do not auto-open the report in the default Markdown viewer.",
    ),
    quiet: bool = typer.Option(
        False,
        "--quiet",
        "-q",
        help="Do not render the report inline in the terminal (file output only).",
    ),
    model: str | None = typer.Option(
        None,
        "--model",
        help=(
            "Override the model for this run. Aliases: 'opus', 'sonnet', 'haiku'. "
            "Or pass any literal claude-* model id. Default = whatever config.yaml says."
        ),
    ),
) -> None:
    """Run the analysis end-to-end. An optional one-shot question may follow."""
    config = _load_config()
    resolved_model, model_display, provider = _resolve_model(model, config)
    if verify:
        _run_verify_checks()
        return
    _ensure_environment(
        cli_required=None if dry_run else provider,
    )

    pm_query = " ".join(query).strip() if query else ""
    prose = PLAYBOOK_PATH.read_text(encoding="utf-8")
    sheet_stats = _compute_sheet_stats()
    user_message = _build_user_message(prose=prose, pm_query=pm_query)

    if dry_run:
        console.print("[bold]── prompt preview (dry run) ──[/bold]\n")
        console.print(user_message)
        console.print(f"\n[dim]System preamble: {len(config['system_preamble'])} chars[/dim]")
        console.print(f"[dim]User message:    {len(user_message)} chars[/dim]")
        console.print(f"[dim]Model:           {model_display} ({resolved_model})[/dim]")
        if pm_query:
            console.print(f"[dim]PM query:        {pm_query!r}[/dim]")
        return

    _print_preflight(
        prose=prose,
        sheet_stats=sheet_stats,
        docs=_list_docs(),
        model_display=model_display,
        pm_query=pm_query,
    )

    output_path = _resolve_output_path(config["output_template"])
    output_path.parent.mkdir(parents=True, exist_ok=True)

    spinner_label = "Codex reasoning…" if provider == "codex" else "Claude reasoning…"
    invoke_fn = _invoke_codex if provider == "codex" else _invoke_claude

    with Progress(
        SpinnerColumn(),
        TextColumn(f"[cyan]{spinner_label}[/cyan]"),
        TimeElapsedColumn(),
        console=console,
        transient=True,  # clear the spinner line once done
    ) as progress:
        progress.add_task("reasoning", total=None)
        result = invoke_fn(
            system_prompt=config["system_preamble"],
            user_message=user_message,
            model=resolved_model,
            progress=progress,
        )

    output_path.write_text(result["text"], encoding="utf-8")
    _update_latest_symlink(output_path)

    if not quiet:
        console.print()
        console.print(Rule("[bold cyan]Report[/bold cyan]", style="cyan"))
        console.print()
        console.print(Markdown(result["text"]))
        console.print()
        console.print(Rule(style="cyan"))

    console.print()
    console.print(
        f"[bold green]✓ Done[/bold green] in {result['duration_ms']/1000:.1f}s "
        f"· ${result['cost_usd']:.4f} "
        f"· {result['input_tokens']:,} in / {result['output_tokens']:,} out tokens"
    )
    console.print(f"  Report:  [cyan]{output_path}[/cyan]")
    console.print(f"  Latest:  [cyan]{OUTPUTS_DIR / 'latest.md'}[/cyan]")
    console.print()

    # Auto-open in default Markdown viewer (macOS).
    if not no_open:
        try:
            subprocess.run(["open", str(OUTPUTS_DIR / "latest.md")], check=False)
        except FileNotFoundError:
            pass  # `open` not available; PM can read manually


@app.command()
def doctor() -> None:
    """Run every preflight check: Python, deps, files, MCP server, claude CLI."""
    _run_doctor_checks()
    console.print("[bold green]✓ doctor: all checks passed[/bold green]")


def _run_doctor_checks() -> None:
    """Extended preflight for ./tune doctor — verifies deps, imports, files, CLI.

    The lighter `_ensure_environment` is what runs on every ./tune call. This
    function is heavier but only runs on demand from `doctor`.
    """
    console.print("[bold]Environment[/bold]")

    # 1. Python version (we use 3.11+ syntax: tuple[str, ...] | None, etc.)
    py = sys.version_info
    if py < (3, 11):
        _die(f"Python ≥ 3.11 required (have {py.major}.{py.minor}.{py.micro})")
    console.print(f"  [green]✓[/green] Python {py.major}.{py.minor}.{py.micro}")

    # 2. uv on PATH (the shebang relies on it).
    if shutil.which("uv") is None:
        _die("`uv` not found on PATH. Install: https://docs.astral.sh/uv/")
    console.print("  [green]✓[/green] uv present on PATH")

    # 3. Python dependencies importable (with versions).
    import importlib.metadata as _md

    deps = ("mcp", "PyYAML", "pandas", "rich", "typer", "openpyxl", "tabulate")
    for spec in deps:
        try:
            ver = _md.version(spec)
            console.print(f"  [green]✓[/green] {spec} {ver}")
        except _md.PackageNotFoundError:
            _die(f"{spec} not installed in this venv. Run: uv sync")

    # 4. MCP server smoke-imports cleanly (no syntax errors, no dep failures).
    if not MCP_SERVER_PATH.exists():
        _die(f"MCP server file missing: {MCP_SERVER_PATH}")
    try:
        from importlib.machinery import SourceFileLoader

        SourceFileLoader("_tune_mcp_doctor", str(MCP_SERVER_PATH)).load_module()
        console.print(f"  [green]✓[/green] {MCP_SERVER_PATH.name} imports cleanly")
    except Exception as e:
        _die(f"{MCP_SERVER_PATH.name} failed to import: {type(e).__name__}: {e}")

    # 5. config.yaml parses and has required keys.
    console.print("[bold]Project files[/bold]")
    if not CONFIG_PATH.exists():
        _die(f"config not found: {CONFIG_PATH}")
    try:
        cfg = yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8"))
    except yaml.YAMLError as e:
        _die(f"config.yaml malformed: {e}")
    if not isinstance(cfg, dict):
        _die("config.yaml does not contain a top-level mapping")
    required = {"model", "system_preamble", "output_template"}
    missing = required - set(cfg.keys())
    if missing:
        _die(f"config.yaml missing keys: {sorted(missing)}")
    console.print(
        f"  [green]✓[/green] config.yaml parses; model={cfg['model']}"
    )

    # 6. Playbook present.
    if not PLAYBOOK_PATH.exists():
        _die(f"playbook not found: {PLAYBOOK_PATH}")
    word_count = len(PLAYBOOK_PATH.read_text(encoding="utf-8").split())
    console.print(
        f"  [green]✓[/green] playbook present: {PLAYBOOK_PATH.name} "
        f"({word_count:,} words)"
    )

    # 7. Sheet present.
    if not SHEET_PATH.exists():
        _die(
            f"sheet not found: {SHEET_PATH}\n"
            "  An engineer drops the source CSV into data/sheets/ once."
        )
    rows = max(0, sum(1 for _ in SHEET_PATH.open()) - 1)
    console.print(
        f"  [green]✓[/green] sheet present: {SHEET_PATH.name} ({rows:,} rows)"
    )

    # 8. data/docs/ folder.
    docs_dir = PROJECT_ROOT / "data" / "docs"
    if not docs_dir.exists():
        _die(f"missing folder: {docs_dir}")
    docs = _list_docs()
    docs_label = ", ".join(docs) if docs else "empty"
    console.print(
        f"  [green]✓[/green] data/docs/ present ({len(docs)} files): {docs_label}"
    )

    # 9. outputs/ writable (create if absent).
    OUTPUTS_DIR.mkdir(parents=True, exist_ok=True)
    if not os.access(OUTPUTS_DIR, os.W_OK):
        _die(f"outputs/ not writable: {OUTPUTS_DIR}")
    console.print(f"  [green]✓[/green] outputs/ writable")

    # 10. LLM CLIs on PATH. Either claude OR codex is enough; doctor reports
    # on both so the PM knows which providers are available.
    console.print("[bold]External tools[/bold]")
    any_cli = False
    for binary, install_hint in (
        ("claude", "Install Claude Code (https://claude.com/code) and run `claude` once to log in."),
        ("codex", "Install OpenAI Codex CLI and run `codex login` once."),
    ):
        if shutil.which(binary) is None:
            console.print(f"  [yellow]✗[/yellow] {binary} CLI not on PATH ({install_hint})")
            continue
        any_cli = True
        try:
            proc = subprocess.run(
                [binary, "--version"], capture_output=True, text=True, timeout=10
            )
            version_line = (proc.stdout.strip() or proc.stderr.strip()).splitlines()[0]
            console.print(f"  [green]✓[/green] {binary} CLI: {version_line}")
        except (subprocess.TimeoutExpired, FileNotFoundError, IndexError):
            console.print(f"  [green]✓[/green] {binary} CLI present on PATH")
    if not any_cli:
        _die("Neither `claude` nor `codex` CLI is on PATH. At least one is required.")

    console.print(
        "[dim]  Note: doctor cannot verify whether `claude` is logged in. "
        "If a real run fails with an auth error, run `claude` interactively once.[/dim]"
    )


def _run_verify_checks() -> None:
    """Validate the playbook's tool calls against the live MCP registry.

    Two layers of checking:
      1. Imports `tune_mcp.py`, which transitively imports every tool file in
         `tools/`. Catches Python errors (syntax errors, missing imports, etc.)
         in any tool file before the PM pays for an LLM run.
      2. Parses the playbook prose for tool-call patterns and validates each
         against the live tool registry: tool name exists, named parameters
         match the tool's input schema.

    Exits 0 on success, non-zero with a clear error otherwise.
    """
    import asyncio
    import difflib
    import re as _re

    console.print("[bold]Verify[/bold]")

    # --- Layer 1: import the MCP server (transitively imports every tool) ---
    try:
        from importlib.machinery import SourceFileLoader

        mcp_module = SourceFileLoader(
            "_verify_mcp_srv", str(MCP_SERVER_PATH)
        ).load_module()
    except Exception as e:
        _die(
            f"failed to import the MCP server:\n  "
            f"{type(e).__name__}: {e}\n  "
            f"This usually means a tool file under tools/ has a Python error."
        )
    console.print(f"  [green]✓[/green] {MCP_SERVER_PATH.name} imports cleanly")

    async def _list_tools_async():
        return await mcp_module.server.list_tools()

    tools = asyncio.run(_list_tools_async())
    tool_index: dict[str, dict[str, Any]] = {}
    for t in tools:
        tool_index[t.name] = {
            "description": t.description or "",
            "schema": t.inputSchema or {},
        }
    console.print(f"  [green]✓[/green] {len(tools)} tool(s) registered")

    # --- Layer 2: parse the playbook for tool calls ---
    if not PLAYBOOK_PATH.exists():
        _die(f"playbook not found: {PLAYBOOK_PATH}")

    prose = PLAYBOOK_PATH.read_text(encoding="utf-8")
    lines = prose.splitlines()
    errors: list[str] = []
    call_count = 0

    # Recognise calls like `tool_name(arg1=value1, arg2=value2)`. Tool names
    # must be referenced by name; freeform mentions in prose are only
    # validated when followed by an opening paren (i.e. call sites).
    call_pattern = _re.compile(r"\b([a-z_][a-z0-9_]*)\s*\(", _re.IGNORECASE)

    # Build a flat index from line offsets to line numbers for nicer errors.
    line_starts: list[int] = [0]
    for line in lines:
        line_starts.append(line_starts[-1] + len(line) + 1)

    def _line_for_offset(off: int) -> int:
        # Binary search would be faster but linear is fine for our prose size.
        for i, start in enumerate(line_starts):
            if start > off:
                return i  # 1-based line number
        return len(lines)

    for m in call_pattern.finditer(prose):
        name = m.group(1)
        # Heuristic: only treat as a tool call if name looks like a tool we know
        # OR it starts with one of our common verbs. Otherwise it's likely a
        # natural-language mention or a function in code prose unrelated to
        # tools — skip silently.
        if name not in tool_index:
            # Suggest if it's close to a known name.
            close = difflib.get_close_matches(name, tool_index.keys(), n=1, cutoff=0.7)
            if close:
                line_no = _line_for_offset(m.start())
                errors.append(
                    f"playbook line {line_no}: unknown tool {name!r}. "
                    f"Did you mean {close[0]!r}?"
                )
            # else: not a tool call, ignore.
            continue

        # We've matched a known tool. Now extract the arguments inside (...).
        call_count += 1
        paren_start = m.end() - 1  # position of the '('
        depth = 0
        end = None
        for i in range(paren_start, len(prose)):
            ch = prose[i]
            if ch == "(":
                depth += 1
            elif ch == ")":
                depth -= 1
                if depth == 0:
                    end = i
                    break
        if end is None:
            line_no = _line_for_offset(m.start())
            errors.append(
                f"playbook line {line_no}: unclosed `(` after tool {name!r}"
            )
            continue
        args_text = prose[paren_start + 1 : end]

        # Pull out the arg keywords. We look for `keyword=...` patterns at the
        # top level (not inside nested parens or quotes).
        kw_pattern = _re.compile(r"([a-zA-Z_][a-zA-Z0-9_]*)\s*=", _re.MULTILINE)
        used_kwargs: set[str] = set()
        for km in kw_pattern.finditer(args_text):
            used_kwargs.add(km.group(1))

        schema = tool_index[name]["schema"]
        valid_params = set((schema.get("properties") or {}).keys())
        unknown = used_kwargs - valid_params
        if unknown:
            line_no = _line_for_offset(m.start())
            for u in sorted(unknown):
                close = difflib.get_close_matches(u, valid_params, n=1, cutoff=0.7)
                hint = f" Did you mean {close[0]!r}?" if close else ""
                errors.append(
                    f"playbook line {line_no}: tool {name!r} has no parameter "
                    f"{u!r}.{hint}"
                )

        # Note: we deliberately do NOT enforce that all required parameters
        # are present, because the LLM is the one calling the tool at runtime.
        # The playbook prose is illustrative; the LLM may fill defaults from
        # the description.

    console.print(f"  [green]✓[/green] {call_count} tool call(s) parsed in playbook")

    if errors:
        err_console.print()
        for e in errors:
            err_console.print(f"  [red]✗[/red] {e}")
        err_console.print()
        _die(f"playbook verify failed: {len(errors)} issue(s) found")

    console.print("[bold green]✓ verify: all tool calls valid[/bold green]")


