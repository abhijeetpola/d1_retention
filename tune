#!/usr/bin/env -S uv run python
"""tune — the only command PMs run.

Workflow:
  1. Read d1-retention-analysis.md (PM-edited prose)
  2. Read data/sheets/d1_retention.csv, filter + slice per config.yaml,
     render as a Markdown table
  3. Build the user message: prose + inlined table + footer telling the LLM
     about list_files / load_file
  4. Write a per-run MCP config pointing at tune_mcp.py
  5. Launch:  claude -p --output-format json --mcp-config <cfg>
              --allowed-tools mcp__sandbox__list_files mcp__sandbox__load_file
              --system-prompt <preamble>  <  combined_user_message
  6. Write the response to outputs/<date>-d1_retention.md (+ outputs/latest.md symlink)
  7. open outputs/latest.md

Usage:
  ./tune                  Run the analysis end-to-end.
  ./tune doctor           Verify environment (claude installed, logged in).
  ./tune --dry-run        Build the prompt and print it; do NOT call claude.
"""

from __future__ import annotations

