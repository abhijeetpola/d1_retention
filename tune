CONFIG_PATH = PROJECT_ROOT / "config.yaml"
OUTPUTS_DIR = PROJECT_ROOT / "outputs"
MCP_SERVER_PATH = PROJECT_ROOT / "tune_mcp.py"

ALLOWED_MCP_TOOLS = " ".join(
    f"mcp__sandbox__{name}"
    for name in (
        "list_files",
        "load_file",
        "compute_rolling_average",
        "compute_stable_baseline",
        "compare_to_baseline",
        "flag_dip_days",
        "compute_signals_for_day",
        "compute_acquisition_mix_shift",
    )
)

# Friendly aliases for the --model flag. Anything not in this map is passed
# through to the underlying CLI verbatim, so future model ids work without code
# changes. Provider is inferred from the resolved model id.
_MODEL_ALIASES = {
    # Anthropic — invoked via `claude -p`.
    "opus": "claude-opus-4-7",
    "sonnet": "claude-sonnet-4-6",
    "haiku": "claude-haiku-4-5-20251001",
    # OpenAI — invoked via `codex exec`.
    "codex": "gpt-5.5",
    "gpt-5.5": "gpt-5.5",
    "gpt5.5": "gpt-5.5",
    "gpt-5": "gpt-5",
}
_MODEL_DISPLAY = {
    "claude-opus-4-7": "Claude Opus 4.7 (1M context)",
    "claude-sonnet-4-6": "Claude Sonnet 4.6",
    "claude-haiku-4-5-20251001": "Claude Haiku 4.5",
    "gpt-5.5": "GPT-5.5 (Codex CLI)",
    "gpt-5": "GPT-5 (Codex CLI)",
}


def _provider_for(model_id: str) -> str:
    """Infer which CLI to shell out to based on the model id prefix."""
    if model_id.startswith("claude-"):
        return "claude"
    if model_id.startswith(("gpt-", "gpt5", "o3", "o4", "o5")):
        return "codex"
    # Default to claude for unknown ids — same fallback the project has used so far.
    return "claude"


def _resolve_model(
    user_choice: str | None, config: dict[str, Any]
) -> tuple[str, str, str]:
    """Return (model_id, display_string, provider). If user_choice is set, append '(override)'."""
    if user_choice:
        model_id = _MODEL_ALIASES.get(user_choice, user_choice)
        display = f"{_MODEL_DISPLAY.get(model_id, model_id)} (override)"
    else:
        model_id = config["model"]
        display = config.get("model_display_name") or _MODEL_DISPLAY.get(model_id, model_id)
    provider = _provider_for(model_id)
    return model_id, display, provider


