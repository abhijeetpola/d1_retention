def _load_config() -> dict[str, Any]:
    if not CONFIG_PATH.exists():
        _die(f"config not found: {CONFIG_PATH}")
    return yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8"))


def _ensure_environment(*, claude_required: bool, verbose: bool = False) -> None:
    if not PLAYBOOK_PATH.exists():
        _die(f"playbook not found: {PLAYBOOK_PATH}")
    if verbose:
        console.print(f"[green]✓[/green] playbook present: {PLAYBOOK_PATH.name}")

    if not SHEET_PATH.exists():
        _die(
            f"sheet not found: {SHEET_PATH}\n"
            "  An engineer drops the source CSV into data/sheets/ once."
        )
    if verbose:
        rows = sum(1 for _ in SHEET_PATH.open()) - 1
        console.print(f"[green]✓[/green] sheet present: {SHEET_PATH.name} ({rows:,} rows)")

    if not MCP_SERVER_PATH.exists():
        _die(f"MCP server missing: {MCP_SERVER_PATH}")
    if verbose:
        console.print(f"[green]✓[/green] MCP server present: {MCP_SERVER_PATH.name}")

    if claude_required:
        if shutil.which("claude") is None:
            _die(
                "`claude` CLI not found on PATH.\n"
                "  Install Claude Code (https://claude.com/code) and run `claude` once "
                "to log in."
            )
        if verbose:
            console.print("[green]✓[/green] claude CLI present on PATH")


def _render_inlined_sheet(inline_cfg: dict[str, Any]) -> tuple[str, dict[str, Any]]:
    """Read the sheet, filter to acquisition_source, take last N days, project columns.

    Returns (markdown_text, summary_dict). summary_dict has rows/cols/days/source and
    full-sheet stats (total_rows, total_cols, min_date, max_date) for the pre-flight line.
    """
    df = pd.read_csv(SHEET_PATH, thousands=",", low_memory=False)

    # Capture full-sheet stats before any filtering.
    full_total_rows = len(df)
    full_total_cols = len(df.columns)

    # Coerce date and sort ascending.
    df["date"] = pd.to_datetime(df["date"], errors="coerce")
    df = df.dropna(subset=["date"]).sort_values("date")

    full_min_date = df["date"].min().strftime("%Y-%m-%d") if len(df) else "?"
    full_max_date = df["date"].max().strftime("%Y-%m-%d") if len(df) else "?"

    # Filter by acquisition_source.
    src_filter = inline_cfg["acquisition_source"]
    if isinstance(src_filter, str):
        src_filter = [src_filter]
    df = df[df["acquisition_source"].isin(src_filter)]

    # Latest N days.
    days = int(inline_cfg.get("days", 180))
    if days > 0:
        cutoff = df["date"].max() - pd.Timedelta(days=days - 1)
        df = df[df["date"] >= cutoff]

    # Project columns.
    cols = inline_cfg["columns"]
    available = [c for c in cols if c in df.columns]
    df = df[available].copy()

    # Make date column readable.
    if "date" in df.columns:
        df["date"] = df["date"].dt.strftime("%Y-%m-%d")

    summary_text = (
        f"_Inlined slice: {len(df):,} rows × {len(df.columns)} cols. "
        f"acquisition_source={src_filter}. "
        f"Last {days} days only._\n\n"
        f"_For per-acquisition-source breakdown or older history, call "
        f"`load_file('sheets/d1_retention.csv')`._\n\n"
    )
    summary_dict = {
        "rows": len(df),
        "cols": len(df.columns),
        "days": days,
        "source": ",".join(src_filter),
        "full_total_rows": full_total_rows,
        "full_total_cols": full_total_cols,
        "full_min_date": full_min_date,
        "full_max_date": full_max_date,
    }
    return summary_text + df.to_markdown(index=False), summary_dict


def _list_docs() -> list[str]:
    """Filenames of any docs the PM has dropped into data/docs/."""
    docs_dir = PROJECT_ROOT / "data" / "docs"
    if not docs_dir.exists():
        return []
    return sorted(
        p.name
        for p in docs_dir.iterdir()
        if p.is_file() and not p.name.startswith(".")
    )


